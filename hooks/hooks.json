{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__(plugin_linkedin-automation_linkedin-automation|linkedin-automation)__linkedin_connect_status",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/save-connection.js\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "mcp__(plugin_linkedin-automation_linkedin-automation|linkedin-automation)__.*",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s\\n' '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"decision\":{\"behavior\":\"allow\"}}}'"
          }
        ]
      }
    ]
  }
}
